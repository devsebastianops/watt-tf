{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Application Configuration Schema",
  "type": "object",
  "properties": {
    "app": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "environment": {
          "type": "string",
          "enum": ["development", "staging", "production"]
        },
        "replicas": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "image": {
          "type": "string",
          "minLength": 1
        },
        "resources": {
          "type": "object",
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "required": ["cpu", "memory"]
        },
        "health_check": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "path": {
              "type": "string"
            },
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            }
          },
          "required": ["enabled", "path", "port"]
        }
      },
      "required": ["name", "version", "environment", "replicas", "image", "resources", "health_check"]
    }
  },
  "required": ["app"]
}
