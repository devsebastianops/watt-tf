{
  "resource": {
    "kubernetes_deployment": {
      "app": {
        "health_check": {
          "enabled": true,
          "path": "/health",
          "port": 8080
        },
        "image": "my-app:latest",
        "name": "my-application",
        "namespace": "production",
        "replicas": 3,
        "resources": {
          "requests": {
            "cpu": "500m",
            "memory": "512Mi"
          }
        }
      }
    }
  }
}
